---
BasedOnStyle: GNU

# No line length limit (GNU defaults to 79)
ColumnLimit: 0

# K&R braces for control statements (GNU uses Allman everywhere)
BreakBeforeBraces: Custom
BraceWrapping:
  AfterCaseLabel: true
  AfterClass: true
  AfterControlStatement: Never
  AfterEnum: true
  AfterFunction: true
  AfterNamespace: true
  AfterObjCDeclaration: true
  AfterStruct: true
  AfterUnion: true
  AfterExternBlock: false
  BeforeElse: false
  BeforeWhile: false
  IndentBraces: false
  SplitEmptyFunction: true
  SplitEmptyRecord: true

# Never sort or reformat includes
SortIncludes: Never

# Keep return type on same line as function name
AlwaysBreakAfterDefinitionReturnType: None
AlwaysBreakAfterReturnType: None

# Multi-line enums
AllowShortEnumsOnASingleLine: false

# Align consecutive #define values
AlignConsecutiveMacros: Consecutive

---
